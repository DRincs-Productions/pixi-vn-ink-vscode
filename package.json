{
  "name": "pixi-vn-ink-vscode",
  "displayName": "%ink.displayName%",
  "description": "%ink.description%",
  "version": "0.5.8",
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRincs-Productions/pixi-vn-ink-vscode.git"
  },
  "author": "drincs-productions",
  "publisher": "drincs-productions",
  "icon": "resources/icon.png",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DRincs-Productions/pixi-vn-ink-vscode/issues"
  },
  "homepage": "https://marketplace.visualstudio.com/items?itemName=drincs-productions.pixi-vn-ink-vscode",
  "funding": "https://github.com/DRincs-Productions/pixi-vn?sponsor=1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "ink",
    "inkle",
    "narrative",
    "pixi-vn",
    "game development"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ink",
        "aliases": [
          "Ink",
          "ink"
        ],
        "extensions": [
          ".ink"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icon.png",
          "dark": "./resources/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ink",
        "scopeName": "source.ink",
        "path": "./syntaxes/ink.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%ink.configuration.title%",
      "properties": {
        "ink.engine": {
          "type": "string",
          "enum": [
            "Inky",
            "pixi-vn"
          ],
          "enumDescriptions": [
            "Inky",
            "Pixi'VN"
          ],
          "default": "Inky",
          "description": "%ink.engine.description%"
        },
        "ink.markup": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "Markdown"
          ],
          "default": null,
          "description": "%ink.markup.description%"
        },
        "ink.mainFile": {
          "type": "string",
          "default": "",
          "description": "%ink.mainFile.description%"
        },
        "ink.rootFolder": {
          "type": "string",
          "default": "",
          "description": "%ink.rootFolder.description%"
        },
        "ink.port": {
          "type": "number",
          "default": 5173,
          "description": "%ink.port.description%"
        }
      }
    },
    "commands": [
      {
        "command": "ink.preview",
        "title": "%ink.preview.title%",
        "icon": "$(eye)",
        "category": "Ink"
      },
      {
        "command": "ink.runProject",
        "title": "%ink.runProject.title%",
        "icon": "$(play)",
        "category": "Ink"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ink.preview",
          "group": "navigation",
          "when": "resourceLangId == ink",
          "icon": "$(eye)",
          "tooltip": "%ink.preview.title%"
        },
        {
          "command": "ink.runProject",
          "group": "navigation",
          "when": "config.ink.mainFile",
          "icon": "$(play)",
          "tooltip": "%ink.runProject.title%"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build-webview": "cd src/webview && npm install && npm run build",
    "compile": "npm run build-webview && npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "l10n-export": "vscode-l10n-dev export --outDir ./l10n ./src",
    "lint": "biome lint",
    "check": "biome check",
    "format": "biome format --write",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@drincs/pixi-vn": "^1.8.0",
    "@drincs/pixi-vn-ink": "^1.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.6.2",
    "@types/vscode": "1.103.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "inkjs": "^2.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
